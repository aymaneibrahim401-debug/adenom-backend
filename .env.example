# Copiez ce fichier en .env et remplissez les valeurs pour le développement
# local (vercel dev). Sur Vercel, ces variables se configurent dans :
# Project Settings -> Environment Variables.

# Identifiants de la base de données Turso (https://turso.tech)
TURSO_DATABASE_URL=libsql://VOTRE-BASE.turso.io
TURSO_AUTH_TOKEN=VOTRE_TOKEN

# Code administrateur pour valider les demandes d'adhésion
ADMIN_CODE=adenom-admin-2026

# Envoi d'email de confirmation via Brevo (https://brevo.com — gratuit, sans domaine)
BREVO_API_KEY=VOTRE_CLE_API_BREVO
BREVO_FROM_EMAIL=votre-adresse-verifiee@gmail.com
BREVO_FROM_NAME=ADENOM

# URL publique du site (utilisée dans le lien de confirmation par email)
SITE_URL=https://votre-projet.vercel.app
